# Optional environment values for yLoader
# Copy this file to .env only if you need custom paths.

# Optional Docker host port overrides (single-container mode)
# YLOADER_FRONTEND_PORT=8080
# YLOADER_BACKEND_PORT=8081

# Backend runtime database location
DB_PATH=./backend-data/metadata.db

# Backend download output location
DOWNLOAD_DIR=./downloads

# Optional explicit yt-dlp binary path
# YT_DLP_PATH=./.tools/yt-dlp-bin/yt-dlp

# Optional explicit ffmpeg/ffprobe paths
# FFMPEG_PATH=./.tools/ffmpeg-bin/linux-x64/bin/ffmpeg
# FFPROBE_PATH=./.tools/ffmpeg-bin/linux-x64/bin/ffprobe

# JavaScript runtime configuration for yt-dlp extractors (YouTube, etc.)
YT_DLP_JS_RUNTIMES=node

# Optional: bypass YouTube bot checks by providing authenticated cookies.
# Use either browser extraction or a cookies file.
# Examples: chrome, firefox, edge
# YT_DLP_COOKIES_FROM_BROWSER=chrome
# YT_DLP_COOKIES_FILE=./cookies.txt

# Optional extractor tuning
# YT_DLP_EXTRACTOR_ARGS=youtube:player_client=android,web

# Optional update strategy: self (binary update) or pip
YT_DLP_UPDATE_METHOD=self

# Optional: mark binaries as yLoader-managed even when they are not under .tools
# Useful for Docker/custom deployments where updater should manage binaries.
# YT_DLP_MANAGED_BY_YLOADER=1
# FFMPEG_MANAGED_BY_YLOADER=1

# Required only if YT_DLP_UPDATE_METHOD=pip
# YT_PIP_PATH=/path/to/pip

# Optional GitHub API token for higher release API rate limits.
# GITHUB_API_TOKEN=ghp_xxx
